generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  password      String?
  daProfile     DaProfile?
  audioRecords  AudioRecord[]
  instrumentals Instrumental[]
  suggestedInstrumentalReferences SuggestedInstrumentalReference[]
  collections   Collection[]
  studioSessions StudioSession[]
  glossaryEntries GlossaryEntry[]
}

model DaProfile {
  id                String   @id @default(cuid())
  userId            String   @unique
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  artistIdentity    String?
  artistsRef        String?
  moods             String?
  instrumentalStyles String?
  influences        String?
  artisticDirection String?
  artisticNotes     String?
  updatedAt         DateTime @updatedAt @default(now())
}

model SuggestedInstrumentalReference {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title           String
  youtubeUrl      String?
  mood            String?
  style           String?
  bpm             Int?
  note            String?
  referenceArtist String?
  scope           String   @default("artist")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
}

model AudioRecord {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title         String
  filePath      String
  duration      Int?
  fileSize      Int?
  mimeType      String?
  format        String?
  checksum      String?
  createdAt     DateTime @default(now())
  status        String   @default("pending")
  transcription Transcription?
  transcriptionJobs TranscriptionJob[]
}

model TranscriptionJob {
  id        String   @id @default(cuid())
  audioId   String
  audio     AudioRecord @relation(fields: [audioId], references: [id], onDelete: Cascade)
  status    String   @default("PENDING")
  progress  Int      @default(0)
  error     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([audioId])
  @@index([status])
}

model Transcription {
  id            String   @id @default(cuid())
  audioRecordId String   @unique
  audioRecord   AudioRecord @relation(fields: [audioRecordId], references: [id], onDelete: Cascade)
  rawText       String?
  cleanText     String?
  lyricsText    String?
  suspiciousWords String?
  validatedWords String?
  lyricsEditedByUser Boolean @default(false)
  cleanLyricsGeneratedAt DateTime?
  lyricsUpdatedAt DateTime?
  segments      Segment[]
  textAnalysis  TextAnalysis?
}

model TextAnalysis {
  id                                  String        @id @default(cuid())
  transcriptionId                     String        @unique
  transcription                       Transcription @relation(fields: [transcriptionId], references: [id], onDelete: Cascade)
  provider                            String        @default("local")
  themesJson                          String        @default("[]")
  moodJson                            String        @default("[]")
  energyScore                         Int           @default(0)
  lyricalScore                        Int           @default(0)
  punchlineScore                      Int           @default(0)
  hookScore                           Int           @default(0)
  daCompatibilityScore                Int           @default(0)
  instrumentalCompatibilityScore      Int           @default(0)
  globalScore                         Int           @default(0)
  summary                             String        @default("")
  strengthsJson                       String        @default("[]")
  weaknessesJson                      String        @default("[]")
  suggestedUse                        String        @default("à retravailler")
  punchlineCandidatesJson             String        @default("[]")
  hookCandidatesJson                  String        @default("[]")
  compatibleInstrumentalsJson         String        @default("[]")
  createdAt                           DateTime      @default(now())
  updatedAt                           DateTime      @updatedAt
}

model GlossaryEntry {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  term       String
  correction String?
  category   String?
  source     String   @default("user")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([userId, term])
  @@index([userId])
}

model Segment {
  id              String   @id @default(cuid())
  transcriptionId String
  transcription   Transcription @relation(fields: [transcriptionId], references: [id], onDelete: Cascade)
  startTime       Float
  endTime         Float
  text            String
  energyScore     Int?
  impactScore     Int?
  themes          Theme[]
  collections     Collection[]
  studioPackSegments StudioPackSegment[]
}

model Theme {
  id       String    @id @default(cuid())
  name     String    @unique
  segments Segment[]
}

model Collection {
  id       String    @id @default(cuid())
  userId   String
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name     String
  type     String    @default("favorites")
  segments Segment[]
}

model StudioSession {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date      DateTime
  intention String?
  studioPacks StudioPack[]
}

model StudioPack {
  id              String   @id @default(cuid())
  studioSessionId String
  studioSession   StudioSession @relation(fields: [studioSessionId], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now())
  name            String
  packSegments    StudioPackSegment[]
  maquettes       Maquette[]
}

model StudioPackSegment {
  id           String     @id @default(cuid())
  studioPackId String
  studioPack   StudioPack @relation(fields: [studioPackId], references: [id], onDelete: Cascade)
  segmentId    String
  segment      Segment    @relation(fields: [segmentId], references: [id], onDelete: Cascade)
  order        Int
  role         String?    // e.g., "Refrain", "Couplet"
}

model Instrumental {
  id              String     @id @default(cuid())
  userId          String?
  user            User?      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name            String
  youtubeUrl      String?
  localPath       String?
  duration        Int?
  fileSize        Int?
  mimeType        String?
  format          String?
  checksum        String?
  bpm             Int?
  musicalKey      String?
  mood            String?
  style           String?
  referenceArtist String?
  rightsStatus    String     @default("inconnu")
  notes           String?
  scope           String     @default("available")
  createdAt       DateTime?  @default(now())
  updatedAt       DateTime?  @updatedAt
  maquettes       Maquette[]

  @@index([userId])
  @@index([scope])
}

model Maquette {
  id             String        @id @default(cuid())
  studioPackId   String
  studioPack     StudioPack    @relation(fields: [studioPackId], references: [id], onDelete: Cascade)
  instrumentalId String
  instrumental   Instrumental  @relation(fields: [instrumentalId], references: [id])
  variant        String        // e.g., "A", "B"
  yaourtAudios   YaourtAudio[]
}

model YaourtAudio {
  id         String   @id @default(cuid())
  maquetteId String
  maquette   Maquette @relation(fields: [maquetteId], references: [id], onDelete: Cascade)
  filePath   String
  createdAt  DateTime @default(now())
}
